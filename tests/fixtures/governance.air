@air 0.2

workflow W(claims: Claim[], consensus: Consensus, vx: Verdict, vy: Verdict, vz: Verdict) -> Artifact:
    node verify_node:
        v1 = verify(claims, product_existence)
        return Artifact(v=v1)

    node aggregate_node:
        c = aggregate([vx, vy, vz], majority)
        return Artifact(c=c)

    node gate_simple:
        outcome = gate(consensus)
        return Artifact(o=outcome)

    node gate_nested:
        outcome = gate(aggregate([vx, vy], majority))
        return Artifact(o=outcome)
