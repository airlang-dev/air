@air 0.2

workflow W -> Artifact:
    node verify_node:
        v1 = verify(claims, product_existence)
        return Artifact(v=v1)

    node aggregate_node:
        c = aggregate([v1, v2, v3], majority)
        return Artifact(c=c)

    node gate_simple:
        outcome = gate(consensus)
        return Artifact(o=outcome)

    node gate_nested:
        outcome = gate(aggregate([v1, v2], majority))
        return Artifact(o=outcome)
