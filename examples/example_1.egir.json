{
  "workflow": "Aurora_Fact_Check",
  "entry": "entry",
  "nodes": {
    "entry": {
      "operations": [
        {
          "type": "llm",
          "inputs": [],
          "outputs": [
            "summary"
          ],
          "params": {
            "prompt": "summarize_aurora"
          }
        },
        {
          "type": "transform",
          "inputs": [
            "summary"
          ],
          "outputs": [
            "claims"
          ],
          "params": {
            "target_type": "Claim[]",
            "via": "extract_claims"
          }
        }
      ],
      "route_variable": "claims",
      "edges": [
        {
          "condition": "Fault",
          "target": "regenerate"
        },
        {
          "condition": "Claim[]",
          "target": "verification"
        }
      ],
      "terminal": false
    },
    "verification": {
      "operations": [
        {
          "type": "verify",
          "inputs": [
            "claims"
          ],
          "outputs": [
            "v1"
          ],
          "params": {
            "rule": "product_existence"
          }
        },
        {
          "type": "verify",
          "inputs": [
            "claims"
          ],
          "outputs": [
            "v2"
          ],
          "params": {
            "rule": "link_validation"
          }
        },
        {
          "type": "verify",
          "inputs": [
            "claims"
          ],
          "outputs": [
            "v3"
          ],
          "params": {
            "rule": "compute_claim"
          }
        },
        {
          "type": "aggregate",
          "inputs": [
            "v1",
            "v2",
            "v3"
          ],
          "outputs": [
            "consensus"
          ],
          "params": {
            "strategy": "majority"
          }
        },
        {
          "type": "gate",
          "inputs": [
            "consensus"
          ],
          "outputs": [
            "outcome"
          ],
          "params": {}
        }
      ],
      "route_variable": "outcome",
      "edges": [
        {
          "condition": "PROCEED",
          "target": "publish"
        },
        {
          "condition": "ESCALATE",
          "target": "review"
        },
        {
          "condition": "RETRY",
          "target": "regenerate"
        },
        {
          "condition": "HALT",
          "target": "abort"
        }
      ],
      "terminal": false
    },
    "regenerate": {
      "operations": [
        {
          "type": "llm",
          "inputs": [],
          "outputs": [
            "summary2"
          ],
          "params": {
            "prompt": "regenerate_summary"
          }
        },
        {
          "type": "transform",
          "inputs": [
            "summary2"
          ],
          "outputs": [
            "claims2"
          ],
          "params": {
            "target_type": "Claim[]",
            "via": "extract_claims"
          }
        }
      ],
      "route_variable": "claims2",
      "edges": [
        {
          "condition": "Claim[]",
          "target": "verification_retry"
        },
        {
          "condition": "continue",
          "target": "regenerate"
        }
      ],
      "terminal": false
    },
    "verification_retry": {
      "operations": [
        {
          "type": "verify",
          "inputs": [
            "claims2"
          ],
          "outputs": [
            "v4"
          ],
          "params": {
            "rule": "product_existence"
          }
        },
        {
          "type": "verify",
          "inputs": [
            "claims2"
          ],
          "outputs": [
            "v5"
          ],
          "params": {
            "rule": "link_validation"
          }
        },
        {
          "type": "verify",
          "inputs": [
            "claims2"
          ],
          "outputs": [
            "v6"
          ],
          "params": {
            "rule": "compute_claim"
          }
        },
        {
          "type": "aggregate",
          "inputs": [
            "v4",
            "v5",
            "v6"
          ],
          "outputs": [
            "consensus2"
          ],
          "params": {
            "strategy": "majority"
          }
        },
        {
          "type": "gate",
          "inputs": [
            "consensus2"
          ],
          "outputs": [
            "outcome2"
          ],
          "params": {}
        }
      ],
      "route_variable": "outcome2",
      "edges": [
        {
          "condition": "PROCEED",
          "target": "publish_retry"
        },
        {
          "condition": "ESCALATE",
          "target": "review"
        },
        {
          "condition": "RETRY",
          "target": "review"
        },
        {
          "condition": "HALT",
          "target": "abort"
        }
      ],
      "terminal": false
    },
    "publish": {
      "operations": [
        {
          "type": "return",
          "inputs": [],
          "outputs": [],
          "params": {
            "type": "Artifact",
            "fields": {
              "status": "verified",
              "summary": "summary",
              "verification": "consensus"
            }
          }
        }
      ],
      "terminal": true
    },
    "publish_retry": {
      "operations": [
        {
          "type": "return",
          "inputs": [],
          "outputs": [],
          "params": {
            "type": "Artifact",
            "fields": {
              "status": "verified_after_retry",
              "summary": "summary2",
              "verification": "consensus2"
            }
          }
        }
      ],
      "terminal": true
    },
    "review": {
      "operations": [
        {
          "type": "decide",
          "inputs": [
            "summary"
          ],
          "outputs": [
            "msg",
            "outcome3"
          ],
          "params": {
            "provider": "human_reviewer"
          }
        }
      ],
      "route_variable": "outcome3",
      "edges": [
        {
          "condition": "PROCEED",
          "target": "publish"
        },
        {
          "condition": "HALT",
          "target": "abort"
        },
        {
          "condition": "ESCALATE",
          "target": "abort"
        },
        {
          "condition": "RETRY",
          "target": "regenerate"
        }
      ],
      "terminal": false
    },
    "abort": {
      "operations": [
        {
          "type": "return",
          "inputs": [],
          "outputs": [],
          "params": {
            "type": "Fault",
            "fields": {
              "reason": "Verification failed"
            }
          }
        }
      ],
      "terminal": true
    }
  }
}